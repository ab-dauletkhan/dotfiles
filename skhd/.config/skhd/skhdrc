# Focus windows
alt - h : yabai -m window --focus west
alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - l : yabai -m window --focus east

# Move windows in the tree
alt + lshift - h : yabai -m window --warp west
alt + lshift - j : yabai -m window --warp south
alt + lshift - k : yabai -m window --warp north
alt + lshift - l : yabai -m window --warp east

# Resize windows
lshift + lctrl - h : yabai -m window --resize left:-50:0;  yabai -m window --resize right:-50:0
lshift + lctrl - j : yabai -m window --resize bottom:0:50; yabai -m window --resize top:0:50
lshift + lctrl - k : yabai -m window --resize top:0:-50;   yabai -m window --resize bottom:0:-50
lshift + lctrl - l : yabai -m window --resize right:50:0;  yabai -m window --resize left:50:0

# Repair / transform layout
hyper - e : yabai -m space --balance
hyper - r : yabai -m space --rotate 90
hyper - x : yabai -m space --mirror x-axis
hyper - y : yabai -m space --mirror y-axis

# Window state
hyper - space : yabai -m window --toggle float
hyper - f     : yabai -m window --toggle zoom-fullscreen

# Focus spaces
hyper - 1 : yabai -m space --focus 1
hyper - 2 : yabai -m space --focus 2
hyper - 3 : yabai -m space --focus 3
hyper - 4 : yabai -m space --focus 4
hyper - 5 : yabai -m space --focus 5
hyper - 6 : yabai -m space --focus 6

# Send window to spaces and follow
shift + hyper - 1 : yabai -m window --space 1 --focus
shift + hyper - 2 : yabai -m window --space 2 --focus
shift + hyper - 3 : yabai -m window --space 3 --focus
shift + hyper - 4 : yabai -m window --space 4 --focus
shift + hyper - 5 : yabai -m window --space 5 --focus
shift + hyper - 6 : yabai -m window --space 6 --focus
